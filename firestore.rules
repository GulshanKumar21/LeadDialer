rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isHR() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/hrs/$(request.auth.uid));
    }

    // Check if user is owner by passing their UID
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ── 1. Admins ─────────────────────────────────────────────────────────
    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── 1b. HRs ───────────────────────────────────────────────────────────
    match /hrs/{userId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── 2. Users / Profiles ───────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isHR() || isOwner(userId);

      // Flutter app: leads as sub-collection under users
      match /leads/{leadId} {
        allow read, write: if isAdmin() || isHR() || isOwner(userId);
      }
    }

    // ── 3. Leads (Native Android app — top-level collection) ──────────────
    match /leads/{leadId} {
      allow read: if isAdmin() || isHR()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isHR()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ── 4. Call Records ───────────────────────────────────────────────────
    match /callRecords/{recordId} {
      allow read: if isAdmin() || isHR()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
    }

    // ── 5. Attendance — flat collection ───────────────────────────────────
    match /attendance/{attendanceId} {
      allow read: if isAdmin() || isHR()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin() || isHR()
        || (isAuthenticated() && request.resource.data.userId == request.auth.uid);

      // Native app: sub-collection (punch-in/out selfie flow)
      match /dates/{date} {
        allow read: if isAdmin() || isHR() || isOwner(attendanceId);
        allow write: if isAdmin() || isHR() || isOwner(attendanceId);
      }
    }

    // ── 6. Leave Requests ─────────────────────────────────────────────────
    match /leaveRequests/{requestId} {
      allow read: if isAdmin() || isHR()
        || (isAuthenticated() && (
          // Flutter uses 'userId', Native uses 'uid'
          resource.data.userId == request.auth.uid ||
          resource.data.uid == request.auth.uid
        ));
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.uid == request.auth.uid
      );
      allow update: if isAdmin() || isHR();
      allow delete: if isAdmin() || isHR();
    }

    // ── 7. Settings (Thought of the Day, etc.) ────────────────────────────
    match /settings/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isHR();
    }

    // ── 8. Device Locks — Attendance device binding (Native) ──────────────
    match /daily_device_locks/{date}/devices/{deviceId} {
      allow read, write: if isAuthenticated();
    }

    // ── 9. Messages — Native app: messages/{userId}/inbox/{msgId} ─────────
    match /messages/{userId}/inbox/{msgId} {
      allow read, update: if isAuthenticated() && userId == request.auth.uid;
      allow create: if isAdmin() || isHR();
      allow delete: if isAdmin() || isHR() || isOwner(userId);

      // Native app replies sub-collection
      match /replies/{replyId} {
        allow read: if isAuthenticated() && (userId == request.auth.uid || isAdmin() || isHR());
        allow create: if isAuthenticated() && userId == request.auth.uid;
        allow delete: if isAdmin() || isHR();
      }
    }

    // ── 10. Messages — Flutter app: messages/{msgId} (top-level) ──────────
    match /messages/{msgId} {
      allow read: if isAuthenticated() && (
        resource.data.recipientId == request.auth.uid || isAdmin() || isHR()
      );
      allow create: if isAdmin() || isHR();
      allow update: if isAuthenticated() && (
        resource.data.recipientId == request.auth.uid || isAdmin() || isHR()
      );
      allow delete: if isAdmin() || isHR();

      // Flutter app replies sub-collection
      match /replies/{replyId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin() || isHR();
      }
    }

    // ── 11. Admin Replies Notifications ───────────────────────────────────
    match /adminReplies/{replyId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin() || isHR();
    }

    // ── 12. HR Portal Specific Collections ────────────────────────────────
    match /recruitment/{docId} {
      allow read, write: if isAdmin() || isHR();
    }

    match /jobOpenings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isHR();
    }

    match /jobApplications/{docId} {
      allow read: if isAdmin() || isHR();
      allow create: if true;
      allow update, delete: if isAdmin() || isHR();
    }


    match /documents/{docId} {
      allow read: if isAuthenticated(); // All employees can read documents/policies
      allow write: if isAdmin() || isHR();
    }

    match /performance/{docId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isHR());
      allow write: if isAdmin() || isHR();
    }

    match /announcements/{docId} {
      allow read: if isAuthenticated(); // All employees can read announcements
      allow write: if isAdmin() || isHR();
    }

    // ── 13. Sales (Dedicated sales collection for analysts) ──────────────
    match /sales/{saleId} {
      allow read: if isAdmin() || isHR()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || isHR()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ── Default Deny ──────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
