<!--  Place this file at: res/font/nunito.xml  -->
<!--
    SETUP STEPS:
    1. Download these .ttf files from https://fonts.google.com/specimen/Nunito
       and place them in res/font/ :
         - nunito_regular.ttf       (Regular 400)
         - nunito_semibold.ttf      (SemiBold 600)
         - nunito_bold.ttf          (Bold 700)
         - nunito_extrabold.ttf     (ExtraBold 800)
         - nunito_black.ttf         (Black 900)
 -->
<font-family xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <!--  Regular 400  -->
    <font android:font="@font/nunito_regular" android:fontStyle="normal" android:fontWeight="400" app:font="@font/nunito_regular" app:fontStyle="normal" app:fontWeight="400"/>
    <!--  SemiBold 600  -->
    <font android:font="@font/nunito_semibold" android:fontStyle="normal" android:fontWeight="600" app:font="@font/nunito_semibold" app:fontStyle="normal" app:fontWeight="600"/>
    <!--  Bold 700  -->
    <font android:font="@font/nunito_bold" android:fontStyle="normal" android:fontWeight="700" app:font="@font/nunito_bold" app:fontStyle="normal" app:fontWeight="700"/>
    <!--  ExtraBold 800  -->
    <font android:font="@font/nunito_extrabold" android:fontStyle="normal" android:fontWeight="800" app:font="@font/nunito_extrabold" app:fontStyle="normal" app:fontWeight="800"/>
    <!--  Black 900  -->
    <font android:font="@font/nunito_black" android:fontStyle="normal" android:fontWeight="900" app:font="@font/nunito_black" app:fontStyle="normal" app:fontWeight="900"/>
</font-family>