<!--  Place this file at: res/font/poppins.xml  -->
<!--
    SETUP STEPS:
    1. Download these .ttf files from https://fonts.google.com/specimen/Poppins
       and place them in res/font/ :
         - poppins_regular.ttf      (Regular 400)
         - poppins_medium.ttf       (Medium 500)
         - poppins_semibold.ttf     (SemiBold 600)
         - poppins_bold.ttf         (Bold 700)
 -->
<font-family xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto">
    <!--  Regular 400  -->
    <font android:font="@font/poppins_regular" android:fontStyle="normal" android:fontWeight="400" app:font="@font/poppins_regular" app:fontStyle="normal" app:fontWeight="400"/>
    <!--  Medium 500  -->
    <font android:font="@font/poppins_medium" android:fontStyle="normal" android:fontWeight="500" app:font="@font/poppins_medium" app:fontStyle="normal" app:fontWeight="500"/>
    <!--  SemiBold 600  -->
    <font android:font="@font/poppins_semibold" android:fontStyle="normal" android:fontWeight="600" app:font="@font/poppins_semibold" app:fontStyle="normal" app:fontWeight="600"/>
    <!--  Bold 700  -->
    <font android:font="@font/poppins_bold" android:fontStyle="normal" android:fontWeight="700" app:font="@font/poppins_bold" app:fontStyle="normal" app:fontWeight="700"/>
</font-family>