<?xml version="1.0" encoding="utf-8"?>

<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#344155">

    <item>

        <shape android:shape="oval">

            <gradient
                android:startColor="#242B38"
                android:endColor="#1A202C"
                android:angle="270"/>

            <stroke
                android:width="1dp"
                android:color="#303A4C"/>

            <corners android:radius="100dp"/>

        </shape>

    </item>

</ripple>