<?xml version="1.0" encoding="utf-8"?>
<!--
    iPhone-style Symmetric 3D Card (GLOBAL)
    Used by: dashboard overview cards, call history, leads, admin cards, etc.
    - Symmetric soft shadow on all 4 sides
    - Pure #FFFFFF milky white face
    - Subtle warm border
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- All-sides ambient shadow (diffused, very soft) -->
    <item android:top="1dp" android:bottom="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0D000000"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- Bottom + right stronger shadow -->
    <item android:top="3dp" android:left="3dp" android:bottom="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#18000000"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- Top-left highlight (light source) -->
    <item android:top="0dp" android:left="0dp" android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#20FFFFFF"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- Card face — pure white, slightly inset -->
    <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <corners android:radius="20dp"/>
            <stroke android:width="0.5dp" android:color="#F2F0EA"/>
        </shape>
    </item>

</layer-list>
