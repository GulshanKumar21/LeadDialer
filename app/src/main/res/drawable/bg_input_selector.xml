<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <shape>
            <gradient
                android:startColor="#1A6B8CFF"
                android:endColor="#112A2A72"
                android:angle="0"/>

            <stroke
                android:width="2dp"
                android:color="#64B5FF"/>

            <corners android:radius="22dp"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#12FFFFFF"/>

            <stroke
                android:width="1dp"
                android:color="#28FFFFFF"/>

            <corners android:radius="22dp"/>
        </shape>
    </item>

</selector>