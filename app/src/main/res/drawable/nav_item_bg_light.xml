<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Selected Item (Brand Orange Light Card Style) -->
    <item android:state_checked="true">
        <inset android:insetTop="6dp" android:insetBottom="6dp" android:insetLeft="18dp" android:insetRight="18dp">
            <layer-list>
                <!-- Soft Warm Shadow -->
                <item
                    android:left="2dp"
                    android:top="2dp"
                    android:right="2dp"
                    android:bottom="2dp">
                    <shape>
                        <solid android:color="#0DFF6A00"/>
                        <corners android:radius="22dp"/>
                    </shape>
                </item>

                <!-- Orange Card Surface -->
                <item>
                    <shape>
                        <gradient
                            android:angle="270"
                            android:startColor="#FFF5ED"
                            android:endColor="#FFEFE5"/>
                        <corners android:radius="22dp"/>
                        <stroke
                            android:width="1.5dp"
                            android:color="#FF6A00"/>
                        <padding
                            android:left="14dp"
                            android:right="14dp"
                            android:top="12dp"
                            android:bottom="12dp"/>
                    </shape>
                </item>
            </layer-list>
        </inset>
    </item>

    <!-- Normal Item (Warm Transparent White Style) -->
    <item>
        <inset android:insetTop="6dp" android:insetBottom="6dp" android:insetLeft="18dp" android:insetRight="18dp">
            <shape>
                <solid android:color="#F8F8F5"/>
                <corners android:radius="22dp"/>
                <stroke
                    android:width="0.5dp"
                    android:color="#E6E6DF"/>
                <padding
                    android:left="14dp"
                    android:right="14dp"
                    android:top="12dp"
                    android:bottom="12dp"/>
            </shape>
        </inset>
    </item>

</selector>
