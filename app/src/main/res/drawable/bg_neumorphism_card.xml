<?xml version="1.0" encoding="utf-8"?>
<!--
    Neumorphism card — symmetric lift from all 4 sides.
    Light from top-left: highlight top-left, shadow bottom-right.
    Card surface = same milky white as background.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Bottom-right dark shadow -->
    <item
        android:top="5dp"
        android:left="5dp"
        android:bottom="0dp"
        android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#D1CBC0"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- Top-left light highlight -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:bottom="5dp"
        android:right="5dp">
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- Main card surface — milky warm white -->
    <item
        android:top="3dp"
        android:left="3dp"
        android:bottom="3dp"
        android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#F8F8F5"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

</layer-list>