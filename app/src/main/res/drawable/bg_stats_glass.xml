<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Milky White Glass -->
    <gradient
        android:angle="270"
        android:startColor="#F9FFFFFF"
        android:centerColor="#F2FFFFFF"
        android:endColor="#ECFFFFFF"/>

    <!-- Rounded Corners -->
    <corners android:radius="28dp"/>

    <!-- Soft Border -->
    <stroke
        android:width="1dp"
        android:color="#40FFFFFF"/>

    <!-- Soft Inner Padding -->
    <padding
        android:left="8dp"
        android:right="8dp"
        android:top="8dp"
        android:bottom="8dp"/>

</shape>