<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Light shadow (top-left highlight) -->
    <item android:left="4dp" android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#F8FAFF"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Soft shadow (bottom-right depth) -->
    <item android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#DDE7FF"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Main surface (glass style) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F4F8FF"
            android:endColor="#EAF2FF"
            android:angle="135"/>
            <corners android:radius="24dp"/>

            <!-- subtle border -->
            <stroke
                android:width="1dp"
                android:color="#20A0BFFF"/>
        </shape>
    </item>

</layer-list>