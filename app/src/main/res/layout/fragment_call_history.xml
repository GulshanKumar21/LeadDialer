<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_milky_white"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- ── Daily Summary Card (3D Style) ── -->
    <FrameLayout
        android:id="@+id/cardDailySummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_summary_3d"
        android:elevation="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btnPrevDay"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="◀"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:id="@+id/tvSummaryTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📊 Today"
                    android:gravity="center"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:id="@+id/btnNextDay"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="▶"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Window label 11:15 AM – 8:00 PM -->
                <TextView
                    android:id="@+id/tvSummaryWindow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="11:15 AM – 8:00 PM"
                    android:textSize="10sp"
                    android:textColor="#FFE0B2"
                    android:fontFamily="@font/poppins_regular" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#60FFFFFF"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Total Calls -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvSummaryTotalCalls"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📞 Calls"
                        android:textSize="11sp"
                        android:textColor="#FFE0B2"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

                <!-- Vertical divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#40FFFFFF"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

                <!-- Total Talk Time -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvSummaryTalkTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🗣 Talk Time"
                        android:textSize="11sp"
                        android:textColor="#FFE0B2"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

                <!-- Vertical divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#40FFFFFF"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp" />

                <!-- Total Gap Time -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:id="@+id/tvSummaryGapTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0m"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⏳ Gap Time"
                        android:textSize="11sp"
                        android:textColor="#FFE0B2"
                        android:fontFamily="@font/poppins_regular" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#60FFFFFF"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="8dp" />

            <!-- Avg per call + Countdown row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSummaryAvg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⌀ Avg/call: —"
                    android:textSize="12sp"
                    android:textColor="#FFE0B2"
                    android:fontFamily="@font/poppins_regular" />

                <!-- Countdown to 8 PM -->
                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🕗 —h —m left"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFE0B2"
                    android:fontFamily="@font/poppins_semibold" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- ── Call History List ── -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCallHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="72dp" />

        <TextView
            android:id="@+id/tvEmptyHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:text="📞 No calls made yet.\nGo to Leads to start calling!"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="#C47A50"
            android:lineSpacingExtra="6dp"
            android:visibility="gone" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabExportCalls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_margin="16dp"
            android:src="@android:drawable/stat_sys_download"
            android:contentDescription="Download call records"/>

    </RelativeLayout>

</LinearLayout>