<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left Status Color Strip -->
        <View
            android:id="@+id/viewStatusStrip"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="#FF6A00" />

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Top Row: Avatar + Info + Call Button -->
            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Avatar circle -->
                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginEnd="14dp">

                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_avatar"/>

                    <!--  hot badge on avatar -->
                    <TextView
                        android:id="@+id/tvHotBadge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:text=""
                        android:textSize="10sp"
                        android:gravity="center"
                        android:layout_gravity="top|end"
                        android:visibility="gone"/>

                </FrameLayout>

                <!-- Info block -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Rahul Kumar"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="#111827"/>

                    <!-- Phone -->
                    <TextView
                        android:id="@+id/tvPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="+91 9876543210"
                        android:textColor="#6B7280"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"/>

                    <!-- College Name -->
                    <TextView
                        android:id="@+id/tvCollegeName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ABC College of Engineering"
                        android:textColor="#FF6A00"
                        android:textSize="12sp"
                        android:fontFamily="@font/nunito_semibold"
                        android:layout_marginTop="3dp"
                        android:visibility="gone"/>

                    <!-- College City -->
                    <TextView
                        android:id="@+id/tvCollegeCity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lucknow"
                        android:textColor="#9CA3AF"
                        android:textSize="11sp"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                    <!-- Status badge pill -->
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textSize="11sp"
                        android:textColor="#FF6A00"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_semibold"
                        android:background="@drawable/bg_pill_orange"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginTop="7dp"/>

                </LinearLayout>

                <!-- Call button — larger, green -->
                <LinearLayout
                    android:id="@+id/btnCall"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_call_btn"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/outline_add_call_24"
                        android:tint="#FFFFFF"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Sales row — shown only for Hot Lead / Interested -->
            <LinearLayout
                android:id="@+id/salesRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Separator -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="10dp"
                    android:background="#F3F4F6" />

                <!-- Buttons row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- Mark Sale Done -->
                    <TextView
                        android:id="@+id/btnMarkSale"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:gravity="center"
                        android:text="Mark as Sale"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.01"
                        android:background="@drawable/bg_btn_sale"
                        android:elevation="2dp"
                        android:stateListAnimator="@null" />

                    <!-- Not Done -->
                    <TextView
                        android:id="@+id/btnMarkNotDone"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="✕  Not Done"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#6B7280"
                        android:letterSpacing="0.01"
                        android:background="@drawable/bg_btn_not_done"
                        android:elevation="1dp"
                        android:stateListAnimator="@null" />

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>