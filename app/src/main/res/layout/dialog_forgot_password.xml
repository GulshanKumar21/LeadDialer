<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_glass"
    android:elevation="32dp"
    android:outlineAmbientShadowColor="#55000000"
    android:outlineSpotShadowColor="#88000000"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="#D1D9E6"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reset Password"
        android:textColor="#2A2A35"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enter your registered email address to receive a password reset link."
        android:textColor="#7A8B99"
        android:textSize="14sp"
        android:layout_marginBottom="24dp"/>

    <EditText
        android:id="@+id/etResetEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Email Address"
        android:inputType="textEmailAddress"
        android:background="@drawable/bg_neu_inset"
        android:padding="16dp"
        android:textColor="#2A2A35"
        android:textColorHint="#7A8B99"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnSendResetLink"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Send Reset Link"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#4285F4"/>

</LinearLayout>
