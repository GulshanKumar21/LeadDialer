<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_milky_white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Change Password"
        android:textSize="20sp"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/nunito_extrabold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp"
        android:text="Your new password will sync to both the app and CRM website."
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="@font/nunito_semibold"/>

    <EditText
        android:id="@+id/etCurrentPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Current Password"
        android:inputType="textPassword"
        android:background="@drawable/bg_search_dark"
        android:padding="14dp"
        android:textSize="14sp"
        android:fontFamily="@font/nunito_semibold"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etNewPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="New Password (min 8 characters)"
        android:inputType="textPassword"
        android:background="@drawable/bg_search_dark"
        android:padding="14dp"
        android:textSize="14sp"
        android:fontFamily="@font/nunito_semibold"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Confirm New Password"
        android:inputType="textPassword"
        android:background="@drawable/bg_search_dark"
        android:padding="14dp"
        android:textSize="14sp"
        android:fontFamily="@font/nunito_semibold"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnConfirmChangePassword"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_button_premium"
        android:text="Update Password"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/nunito_extrabold"
        android:textSize="14sp"
        android:textAllCaps="false"/>

</LinearLayout>
