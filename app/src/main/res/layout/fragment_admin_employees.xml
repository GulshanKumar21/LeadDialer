<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_milky_white">

    <!-- Search bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <androidx.cardview.widget.CardView
            style="@style/IPhoneCardView"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="24dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="#A0AAB5"
                    android:layout_marginEnd="12dp"/>

                <EditText
                    android:id="@+id/etSearchEmployee"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="Search employees..."
                    android:background="@null"
                    android:inputType="text"
                    android:singleLine="true"
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#A0AAB5"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Summary cards row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp">

        <!-- Employees card -->
        <androidx.cardview.widget.CardView
            style="@style/IPhoneCardView"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTotalEmployees"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#3B82F6"
                    android:textSize="28sp"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Employees"
                    android:textColor="#64748B"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Total Leads card -->
        <androidx.cardview.widget.CardView
            style="@style/IPhoneCardView"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTotalAllLeads"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#8B5CF6"
                    android:textSize="28sp"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Leads"
                    android:textColor="#64748B"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Connected card -->
        <androidx.cardview.widget.CardView
            style="@style/IPhoneCardView"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTotalConnected"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#10B981"
                    android:textSize="28sp"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected"
                    android:textColor="#64748B"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sales Done card -->
        <androidx.cardview.widget.CardView
            style="@style/IPhoneCardView"
            android:layout_width="0dp"
            android:layout_height="84dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvTotalSales"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#1B7A34"
                    android:textSize="28sp"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sales"
                    android:textColor="#64748B"
                    android:textSize="12sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Employee list label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="10dp">

        <View
            android:layout_width="4dp"
            android:layout_height="18dp"
            android:background="#4285F4"
            android:layout_marginEnd="10dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="All Employees"
            android:textColor="#1A1A2E"
            android:textSize="18sp"
            android:fontFamily="@font/poppins_semibold"
            android:letterSpacing="0.02"/>

        <TextView
            android:id="@+id/tvManageTlsAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage TLs"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/poppins_semibold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/bg_neu_btn_blue"
            android:elevation="2dp"
            android:layout_marginEnd="4dp"/>

        <ProgressBar
            android:id="@+id/progressAdmin"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Employee RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEmployees"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"/>

</LinearLayout>
