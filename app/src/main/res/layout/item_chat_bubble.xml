<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Admin bubble (left-aligned) -->
    <LinearLayout
        android:id="@+id/layoutAdminBubble"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start"
        android:visibility="gone">

        <TextView
            android:text="👤"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvBubbleFrom"
                android:text="Admin"
                android:textSize="11sp"
                android:textColor="#FF6A00"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"


                app:cardBackgroundColor="#FFFFFF">

                <TextView
                    android:id="@+id/tvBubbleText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:textSize="14sp"
                    android:textColor="#1A1A2E"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"/>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvBubbleTime"
                android:text="2m ago"
                android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

        <!-- spacer so admin bubble doesn't go full width -->
        <View android:layout_width="56dp" android:layout_height="1dp"/>
    </LinearLayout>

    <!-- Employee reply bubble (right-aligned) -->
    <LinearLayout
        android:id="@+id/layoutReplyBubble"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="gone">

        <!-- spacer -->
        <View android:layout_width="56dp" android:layout_height="1dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvReplyFrom"
                android:text="You"
                android:textSize="11sp"
                android:textColor="#6366F1"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="3dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"


                app:cardBackgroundColor="#FF6A00">

                <TextView
                    android:id="@+id/tvReplyText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:lineSpacingMultiplier="1.3"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"/>

            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvReplyTime"
                android:text="Just now"
                android:textSize="10sp"
                android:textColor="#9CA3AF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

        <TextView
            android:text="🙋"
            android:textSize="18sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</LinearLayout>
