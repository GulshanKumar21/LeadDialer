<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"


    android:outlineAmbientShadowColor="#55000000"
    android:outlineSpotShadowColor="#88000000"
    app:cardBackgroundColor="@color/card_bg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvTitle"
                android:text="Call Summary"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#1A1A2E"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvDetails"
                android:text="Rahul • 1m 20s"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginTop="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tvCallTime"
                android:text="Called at: 10:30 AM"
                android:textSize="13sp"
                android:textColor="#3B82F6"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Save as Lead banner: shown only for unknown/manual numbers -->
            <LinearLayout
                android:id="@+id/layoutSaveLead"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="#E6FAF8"
                android:padding="10dp"
                android:gravity="center_vertical"
                android:visibility="gone">

                <TextView
                    android:text=""
                    android:textSize="20sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:text="Unknown number — Save as Lead?"
                    android:textSize="13sp"
                    android:textColor="#0F766E"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnSaveAsLead"
                    android:text="Save"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#0D9488"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    app:cornerRadius="18dp"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="14dp"
                android:background="#F3F4F6"/>

            <TextView
                android:text="MARK STATUS"
                android:textSize="11sp"
                android:textColor="#9CA3AF"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnInterested"
                    android:text="Interested"
                    android:backgroundTint="#6366F1"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:gravity="center"
                    android:padding="6dp"
                    app:cornerRadius="12dp"/>

                <Button
                    android:id="@+id/btnBusy"
                    android:text="Busy"
                    android:backgroundTint="#F59E0B"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:gravity="center"
                    android:padding="6dp"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnNotConnected"
                    android:text="No Answer"
                    android:backgroundTint="#EF4444"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:gravity="center"
                    android:padding="6dp"
                    app:cornerRadius="12dp"/>

                <Button
                    android:id="@+id/btnNotInterested"
                    android:text="Not Interested"
                    android:backgroundTint="#6B7280"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:gravity="center"
                    android:padding="6dp"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <Button
                    android:id="@+id/btnCustom"
                    android:text="Custom"
                    android:backgroundTint="#8B5CF6"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:gravity="center"
                    android:padding="6dp"
                    app:cornerRadius="12dp"/>

                <Button
                    android:id="@+id/btnConnected"
                    android:text="Wrong Number"
                    android:backgroundTint="#8B0000"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:minHeight="52dp"
                    android:gravity="center"
                    android:padding="6dp"
                    app:cornerRadius="12dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSkip"
                android:text="Skip"
                android:textColor="#9CA3AF"
                android:backgroundTint="#F9FAFB"
                android:layout_marginTop="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="46dp"
                android:gravity="center"
                app:cornerRadius="12dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.google.android.material.card.MaterialCardView>