<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    style="@style/IPhoneCardView"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="12dp"
    android:layout_marginTop="6dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Content Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Status Accent Bar -->
            <View
                android:id="@+id/viewStatusBar"
                android:layout_width="4dp"
                android:layout_height="50dp"
                android:background="#FFA500"
                android:layout_marginEnd="14dp"/>

            <!-- Info Column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Employee name: visible only in admin mode -->
                <TextView
                    android:id="@+id/tvEmployeeName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FF6A00"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvLeaveType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sick Leave"
                    android:textColor="#1A1A2E"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:id="@+id/tvLeaveDates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#64748B"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/tvLeaveReason"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#475569"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/tvLeaveStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:background="#FFA500"/>
        </LinearLayout>

        <!-- Admin Action Buttons — only shown when pending in admin view -->
        <LinearLayout
            android:id="@+id/layoutAdminActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btnApproveLeave"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="✅ Approve"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#27AE60"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnRejectLeave"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="❌ Reject"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E74C3C"
                android:stateListAnimator="@null"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
