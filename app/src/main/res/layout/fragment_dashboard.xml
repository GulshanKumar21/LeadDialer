<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_milky_white"
    android:scrollbars="none"
    android:clipToPadding="false"
    android:clipChildren="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_dashboard_hero"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="52dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good Morning, ✨"
                        android:textColor="#888888"
                        android:textSize="13sp"
                        android:fontFamily="@font/nunito_semibold"/>

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gulshan 👋"
                        android:textColor="#111111"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_extrabold"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>
            </LinearLayout>


            <!-- Mini Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass_mini_stat"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:elevation="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:id="@+id/tvHeroTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111111"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_extrabold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:fontFamily="@font/nunito_semibold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass_mini_stat"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:elevation="16dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:id="@+id/tvHeroConnected"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111111"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_extrabold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Called"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:fontFamily="@font/nunito_semibold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass_mini_stat"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:elevation="16dp">
                    <TextView
                        android:id="@+id/tvHeroHot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111111"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_extrabold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📵 Busy"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:fontFamily="@font/nunito_semibold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_glass_mini_stat"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp"
                    android:elevation="16dp"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:id="@+id/tvHeroSales"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111111"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_extrabold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ Sales"
                        android:textColor="#666666"
                        android:textSize="11sp"
                        android:fontFamily="@font/nunito_semibold"/>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- ══ SLIDER ══ -->
        <androidx.cardview.widget.CardView
    style="@style/IPhoneCardView"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp"
            android:stateListAnimator="@animator/lift_on_touch"


            app:cardBackgroundColor="#000000">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Banner Image -->
                <ImageView
                    android:id="@+id/bannerImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/studentbanner"
                    android:scaleType="centerCrop"
                    android:alpha="0" />

                <!-- Soft Dark Overlay -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#22000000" />

                <!-- Animated Intro Container -->
                <LinearLayout
                    android:id="@+id/textContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingStart="26dp"
                    android:paddingEnd="26dp"
                    android:paddingTop="18dp"
                    android:paddingBottom="18dp"
                    android:background="@drawable/bg_intro_text">

                    <!-- Main Typing Text -->
                    <TextView
                        android:id="@+id/tvAnimated"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADYAPANSCHOOL"
                        android:textColor="#FFFFFF"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:singleLine="true"
                        android:maxLines="1"
                        android:includeFontPadding="false"
                        android:gravity="center"
                        android:textAlignment="center"
                        android:letterSpacing="0.04"
                        android:fontFamily="sans-serif-black"/>

                    <TextView
                        android:id="@+id/tvAnimated2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="India's Largest Student Community"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="8dp"
                        android:letterSpacing="0.06"
                        android:gravity="center"
                        android:alpha="0.85" />

                </LinearLayout>

            </FrameLayout>

        </androidx.cardview.widget.CardView>

        <!-- ══ TODAY'S GOAL CARD ══ -->
        <androidx.cardview.widget.CardView
           style="@style/IPhoneCardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:stateListAnimator="@animator/lift_on_touch"


            app:cardUseCompatPadding="false"
            android:translationZ="4dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯  Today's Goal"
                        android:textColor="#FCA362"
                        android:textSize="11sp"
                        android:fontFamily="@font/nunito_semibold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvProgressLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 / 0 leads called"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_extrabold"
                        android:layout_marginBottom="10dp"/>

                    <ProgressBar
                        android:id="@+id/progressGoal"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:max="100"
                        android:progress="0"
                        android:progressDrawable="@drawable/bg_goal_progress_bar"/>

                    <!-- Expected Sales UI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_neu_inset"
                        android:padding="8dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Your Expected Sales Today"
                            android:textColor="#7A8B99"
                            android:textSize="11sp"
                            android:fontFamily="@font/nunito_semibold"/>

                        <TextView
                            android:id="@+id/tvExpectedSales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#1B7A34"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_extrabold"
                            android:layout_marginEnd="8dp"
                            android:layout_marginStart="4dp"/>

                        <ImageButton
                            android:id="@+id/btnEditExpectedSales"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_edit"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="#4285F4"/>
                    </LinearLayout>

                    <!-- Admin Target UI -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_neu_inset"
                        android:padding="8dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🎯 Assigned Target"
                            android:textColor="#7A8B99"
                            android:textSize="11sp"
                            android:fontFamily="@font/nunito_semibold"/>

                        <TextView
                            android:id="@+id/tvAdminTargetDashboard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Not Set"
                            android:textColor="#7B1FA2"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_extrabold"
                            android:layout_marginEnd="8dp"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#FCA362"
                    android:textSize="30sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/nunito_extrabold"
                    android:layout_marginStart="16dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══ OVERVIEW LABEL ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_accent_bar_gradient"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Overview"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/nunito_extrabold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textColor="#FCA362"
                android:textSize="11sp"
                android:fontFamily="@font/nunito_semibold"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    style="@style/IPhoneCardView"
                    android:id="@+id/cardTotalLeads"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:stateListAnimator="@animator/lift_on_touch"


                    app:cardUseCompatPadding="false"
                    android:translationZ="0dp"
                    app:cardBackgroundColor="@android:color/transparent">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_3d"
                        android:padding="18dp">
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_orange_light">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_group"
                                app:tint="#FCA362"/>
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tvTotalLeads"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#111111"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_extrabold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Leads"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/nunito_semibold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
    style="@style/IPhoneCardView"
                    android:id="@+id/cardConnected"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:stateListAnimator="@animator/lift_on_touch"


                    app:cardUseCompatPadding="false"
                    android:translationZ="0dp"
                    app:cardBackgroundColor="@android:color/transparent">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_3d"
                        android:padding="18dp">
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_orange_light">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_phone"
                                app:tint="#FCA362"/>
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tvConnected"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#111111"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_extrabold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Connected"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/nunito_semibold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:weightSum="2"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
    style="@style/IPhoneCardView"
                    android:id="@+id/cardInterested"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:stateListAnimator="@animator/lift_on_touch"


                    app:cardUseCompatPadding="false"
                    android:translationZ="0dp"
                    app:cardBackgroundColor="@android:color/transparent">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_3d"
                        android:padding="18dp">
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_orange_light">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="📵"
                                android:textSize="18sp"/>
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tvInterested"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#111111"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_extrabold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Busy"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/nunito_semibold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
    style="@style/IPhoneCardView"
                    android:id="@+id/cardPending"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:stateListAnimator="@animator/lift_on_touch"


                    app:cardUseCompatPadding="false"
                    android:translationZ="0dp"
                    app:cardBackgroundColor="@android:color/transparent">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card_3d"
                        android:padding="18dp">
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_orange_light">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_clock"
                                app:tint="#FCA362"/>
                        </FrameLayout>
                        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tvPending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#111111"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_extrabold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/nunito_semibold"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <androidx.cardview.widget.CardView
    style="@style/IPhoneCardView"
                android:id="@+id/cardSalesDone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:stateListAnimator="@animator/lift_on_touch"


                app:cardUseCompatPadding="false"
                android:translationZ="0dp"
                app:cardBackgroundColor="@android:color/transparent">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card_3d"
                    android:padding="18dp"
                    android:gravity="center_vertical">
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_icon_orange_light"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="✅"
                            android:textSize="22sp"/>
                    </FrameLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sales Done"
                            android:textColor="#888888"
                            android:textSize="13sp"
                            android:fontFamily="@font/nunito_semibold"/>
                        <TextView
                            android:id="@+id/tvSalesDone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#111111"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/nunito_extrabold"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Leads Converted"
                        android:textColor="#1B7A34"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/nunito_semibold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- ══ QUICK ACTIONS LABEL ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="14dp">

            <View
                android:layout_width="4dp"
                android:layout_height="20dp"
                android:background="@drawable/bg_accent_bar_gradient"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thought of the Day"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/nunito_extrabold"/>

        </LinearLayout>

        <androidx.cardview.widget.CardView
    style="@style/IPhoneCardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            android:stateListAnimator="@animator/lift_on_touch"


            app:cardUseCompatPadding="false"
            android:translationZ="4dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_motivation_card"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💡"
                    android:textSize="28sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvThought"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="\The secret of getting ahead is getting started. Every call brings you closer to your goal.\"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:fontFamily="@font/nunito_semibold"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/tvThoughtAuthor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— Adyapan Team"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:fontFamily="@font/nunito_semibold"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>