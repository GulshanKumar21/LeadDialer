<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    style="@style/IPhoneCardView"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginBottom="14dp"
    android:layout_marginTop="6dp"
    app:cardCornerRadius="16dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: avatar + name + actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Gradient Avatar -->
            <TextView
                android:id="@+id/tvEmployeeAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_avatar"
                android:layout_marginEnd="14dp"
                android:elevation="3dp"/>

            <!-- Name + email + TL badge -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvEmployeeName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:fontFamily="@font/poppins_semibold"
                    android:letterSpacing="0.01"/>

                <TextView
                    android:id="@+id/tvEmployeeEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="1dp"/>

                <!-- TL Badge — shown only if employee has a TL -->
                <TextView
                    android:id="@+id/tvTlBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#1D4ED8"
                    android:textStyle="bold"
                    android:background="@drawable/bg_stat_blue"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginTop="6dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Message + Edit buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnSendMessage"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@android:drawable/ic_dialog_email"
                    android:background="@drawable/bg_icon_pill_orange"
                    android:layout_marginEnd="8dp"
                    android:padding="8dp"
                    app:tint="#FFFFFF"/>

                <ImageButton
                    android:id="@+id/btnEditProfile"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_edit"
                    android:background="@drawable/bg_icon_pill_blue"
                    android:padding="8dp"
                    app:tint="#FFFFFF"/>

            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"/>

        <!-- Stats row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Leads -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_orange"
                android:padding="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvLeadCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FF6A00"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Leads"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Connected -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_teal"
                android:padding="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvConnectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#00897B"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Interested -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_blue"
                android:padding="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvInterestedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interested"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Sales Done -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_green"
                android:padding="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvSalesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1B7A34"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sales"
                    android:textSize="9sp"
                    android:textColor="#888888"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Expected -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_purple"
                android:padding="8dp">
                <TextView
                    android:id="@+id/tvExpectedSales"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="#7B1FA2"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target"
                    android:textSize="10sp"
                    android:textColor="#64748B"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Admin Target row (tappable — opens Set Target dialog) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_neu_inset"
            android:padding="10dp"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvAdminTarget"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🎯 Set Admin Target"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="#1A1A2E"
                android:gravity="center_vertical"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" ✏️ Tap to edit"
                android:textSize="12sp"
                android:textColor="#64748B"/>
        </LinearLayout>

        <!-- TL Assignment row — admin assigns TL directly from card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_stat_blue"
            android:padding="10dp"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 TL:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A5276"
                android:layout_marginEnd="8dp"/>

            <Spinner
                android:id="@+id/spinnerTlAssign"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_neu_inset"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"/>

        </LinearLayout>

        <!-- View Details arrow -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:layout_marginTop="10dp">
            <ImageView
                android:id="@+id/btnEditProfile_placeholder"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Details  ›"
                android:textSize="11sp"
                android:textColor="#FF6A00"
                android:textStyle="bold"
                android:fontFamily="@font/poppins_semibold"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
