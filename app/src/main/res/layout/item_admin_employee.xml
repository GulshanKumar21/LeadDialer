<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.MaterialComponents.CardView"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="14dp"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="12dp"
    android:layout_marginTop="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0.5dp"
    app:strokeColor="#C6C6C8"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Section 1: Avatar + Name/Email + Success Rate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp">

            <!-- Gradient Avatar -->
            <TextView
                android:id="@+id/tvEmployeeAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_avatar_gradient" />

            <!-- Details: Name + Email + TL Badge -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp">

                <TextView
                    android:id="@+id/tvEmployeeName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="#111827"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvEmployeeEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#6C6C70"
                    android:layout_marginTop="1dp"
                    android:singleLine="true"
                    android:ellipsize="end"/>

                <!-- TL Badge -->
                <TextView
                    android:id="@+id/tvTlBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="9sp"
                    android:textColor="@color/brand_orange"
                    android:textStyle="bold"
                    android:background="@drawable/bg_tl_badge"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone"/>

            </LinearLayout>

            <!-- Success Rate -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvSuccessRate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="#6C6C70"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="success rate"
                    android:textSize="10sp"
                    android:textColor="#AEAEB2"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E5E5EA"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"/>

        <!-- Section 2: 5 Stats Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="12dp">

            <!-- Total Leads -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_orange"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvLeadCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/brand_orange"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total"
                    android:textSize="10sp"
                    android:textColor="#AEAEB2"/>
            </LinearLayout>

            <!-- Connected Leads -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_teal"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvConnectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#00897B"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected"
                    android:textSize="10sp"
                    android:textColor="#AEAEB2"/>
            </LinearLayout>

            <!-- Interested Leads -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_blue"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvInterestedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Interested"
                    android:textSize="10sp"
                    android:textColor="#AEAEB2"/>
            </LinearLayout>

            <!-- Sales Leads -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_green"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layout_marginEnd="6dp">
                <TextView
                    android:id="@+id/tvSalesCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#16A34A"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sales"
                    android:textSize="10sp"
                    android:textColor="#AEAEB2"/>
            </LinearLayout>

            <!-- Target -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_stat_purple"
                android:paddingTop="8dp"
                android:paddingBottom="8dp">
                <TextView
                    android:id="@+id/tvExpectedSales"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#7C3AED"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Target"
                    android:textSize="10sp"
                    android:textColor="#AEAEB2"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Section 3: Action Buttons (3 rows) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Row 1: Message & View Leads -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendMessage"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Message"
                    android:textColor="@color/brand_orange"
                    app:strokeColor="@color/brand_orange"
                    app:strokeWidth="0.8dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_nav_messages"
                    app:iconTint="@color/brand_orange"
                    app:iconSize="16dp"
                    app:iconGravity="textStart"
                    android:textSize="12sp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="match_parent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnViewLeads"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="View Leads"
                    android:textColor="@color/brand_orange"
                    app:backgroundTint="@color/brand_orange_light"
                    app:elevation="0dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_nav_employees"
                    app:iconTint="@color/brand_orange"
                    app:iconSize="16dp"
                    app:iconGravity="textStart"
                    android:textSize="12sp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

            </LinearLayout>

            <!-- Row 2: Attendance -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAttendance"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Attendance"
                android:textColor="#34C759"
                app:strokeColor="#34C759"
                app:strokeWidth="0.8dp"
                app:cornerRadius="10dp"
                app:icon="@drawable/ic_attendance"
                app:iconTint="#34C759"
                app:iconSize="14dp"
                app:iconGravity="textStart"
                android:textSize="11sp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <!-- Row 3: Edit Profile & Set Target -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEditProfile"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Edit Profile"
                    android:textColor="@color/brand_orange"
                    app:strokeColor="@color/brand_orange"
                    app:strokeWidth="0.8dp"
                    app:cornerRadius="10dp"
                    app:icon="@drawable/ic_edit"
                    app:iconTint="@color/brand_orange"
                    app:iconSize="14dp"
                    app:iconGravity="textStart"
                    android:textSize="11sp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp" />

                <View
                    android:layout_width="8dp"
                    android:layout_height="match_parent" />

                <FrameLayout
                    android:id="@+id/rowAdminTarget"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tvAdminTarget"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Set Target"
                        android:textColor="#FFFFFF"
                        app:backgroundTint="@color/brand_orange"
                        app:cornerRadius="10dp"
                        app:icon="@drawable/ic_target"
                        app:iconTint="#FFFFFF"
                        app:iconSize="14dp"
                        app:iconGravity="textStart"
                        android:textSize="11sp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:clickable="false"
                        android:focusable="false" />

                </FrameLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
