<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@android:color/white"
    android:padding="12dp"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="4dp"
    android:layout_marginBottom="4dp"
    android:elevation="2dp"
    android:gravity="center_vertical">

    <!-- Date -->
    <TextView
        android:id="@+id/tvDayDate"
        android:layout_width="0dp"
        android:layout_weight="1.3"
        android:layout_height="wrap_content"
        android:text="Mon, 03 Jun"
        android:textColor="#374151"
        android:textSize="12sp"
        android:textStyle="bold"/>

    <!-- Status Badge -->
    <TextView
        android:id="@+id/tvDayStatus"
        android:layout_width="0dp"
        android:layout_weight="1.0"
        android:layout_height="wrap_content"
        android:text="Present"
        android:textSize="10sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="4dp"
        android:background="@drawable/bg_neu_surface"/>

    <!-- Time -->
    <TextView
        android:id="@+id/tvDayTime"
        android:layout_width="0dp"
        android:layout_weight="1.6"
        android:layout_height="wrap_content"
        android:text="In: 09:30  Out: 19:00"
        android:textColor="#6B7280"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginStart="4dp"/>

    <!-- Photo Icon (camera) — visible only if attendance present -->
    <ImageView
        android:id="@+id/ivDayPhoto"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_camera"
        android:layout_marginStart="6dp"
        android:contentDescription="View selfie"
        android:visibility="gone"/>

</LinearLayout>
