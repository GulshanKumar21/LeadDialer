<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_glass">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👥 Manage Team Leaders"
        android:textColor="#1A202C"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Existing TL list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTeamLeaders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="240dp"
        android:nestedScrollingEnabled="true"
        android:layout_marginBottom="16dp"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginBottom="16dp"/>

    <!-- Add / Edit TL -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add / Edit Team Leader"
        android:textColor="#4A5568"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <!-- Employee dropdown label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👤 Select Employee as TL"
        android:textColor="#4A5568"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <!-- Employee name spinner — auto-fills UID -->
    <Spinner
        android:id="@+id/spinnerTlEmployee"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_neu_inset"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:layout_marginBottom="10dp"/>

    <!-- Sheet URL label -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="🔗 Google Sheet Script URL"
            android:textColor="#4A5568"
            android:textSize="12sp"/>

        <!-- "Change Sheet" hint chip -->
        <TextView
            android:id="@+id/tvChangeSheetHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Sheet full? Change URL"
            android:textColor="#4285F4"
            android:textSize="11sp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#E8F0FE"
            android:textStyle="bold"/>
    </LinearLayout>

    <EditText
        android:id="@+id/etTlSheetUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Paste new Google Apps Script URL here"
        android:background="@drawable/bg_neu_inset"
        android:padding="14dp"
        android:textColor="#2A2A35"
        android:textColorHint="#7A8B99"
        android:inputType="textUri"
        android:layout_marginBottom="6dp"/>

    <!-- Info note -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ℹ️  Jab sheet full ho jaye: naya GAS script deploy karo, URL yahan paste karo aur Save karo."
        android:textColor="#718096"
        android:textSize="11sp"
        android:layout_marginBottom="14dp"/>

    <!-- Hidden field to carry UID — set programmatically -->
    <EditText
        android:id="@+id/etTlUserId"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <!-- Save Button -->
    <Button
        android:id="@+id/btnAddTl"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="💾 Save Team Leader"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:backgroundTint="#4285F4"
        android:layout_marginBottom="8dp"/>

    <!-- Close -->
    <Button
        android:id="@+id/btnCloseTlDialog"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Close"
        android:textColor="#4A5568"
        android:backgroundTint="#EDF2F7"/>

</LinearLayout>
