<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="adyapan_prefs.xml"/>
        <exclude domain="sharedpref" path="CallManager.xml"/>
        <exclude domain="sharedpref" path="app.xml"/>
        <exclude domain="sharedpref" path="sim_prefs.xml"/>
        <exclude domain="sharedpref" path="theme_prefs.xml"/>
        <exclude domain="database" path="lead_dialer.db"/>
        <exclude domain="database" path="lead_dialer.db-shm"/>
        <exclude domain="database" path="lead_dialer.db-wal"/>
        <exclude domain="cache" path="."/>
