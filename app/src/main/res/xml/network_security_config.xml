<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 🔒 SECURITY: Block all cleartext traffic everywhere -->
    <base-config cleartextTrafficPermitted="false" />

    <!--
        🔒 SECURITY: Certificate Pinning — Firebase & Google APIs
        ⚠️  EXPIRY: 2027-06-01 — update pins before this date!
        ⚠️  Only applies to RELEASE builds.
              Debug builds skip pinning via <debug-overrides> trust-anchors.
        Pins: Google Trust Services GTS Root R1, R2 + GlobalSign Root CA R2
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">firebaseio.com</domain>
        <domain includeSubdomains="true">firestore.googleapis.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">firebase.google.com</domain>
        <domain includeSubdomains="true">script.google.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
        <pin-set expiration="2027-06-01">
            <!-- Google Trust Services GTS Root R1 (Primary) -->
            <pin digest="SHA-256">hxqRlPTu1bMS/0DITB1SSu0vd4u/8l8TjPgfaAp63Gc=</pin>
            <!-- Google Trust Services GTS Root R2 (Backup) -->
            <pin digest="SHA-256">/zQvtsTIvTCkcmCeoWJKxK7O6huoSoWIQtnMkfJlO0g=</pin>
            <!-- GlobalSign Root CA R2 (Legacy backup) -->
            <pin digest="SHA-256">iie1VXtL7HzAMF+/PVPR9xzT80kQxdZeJ+zduCB3uj0=</pin>
        </pin-set>
    </domain-config>

    <!--
        🔒 DEBUG OVERRIDE:
        - User-installed certs allowed (e.g. Charles Proxy for testing)
        - Pin-set is NOT applied in debug — prevents false connectivity failures
        - In release builds this block is IGNORED by Android
    -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
