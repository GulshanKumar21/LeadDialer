<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--  SECURITY: Block all cleartext traffic everywhere -->
    <base-config cleartextTrafficPermitted="false" />

    <!--
         SECURITY: Google Trust Services & Firebase Connections
        - Cleartext is blocked.
        - Enforces standard secure HTTPS using Android's system certificates.
        - SSL certificate pinning removed to prevent "Pin verification failed" login errors.
    -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">firebaseio.com</domain>
        <domain includeSubdomains="true">firestore.googleapis.com</domain>
        <domain includeSubdomains="true">googleapis.com</domain>
        <domain includeSubdomains="true">firebase.google.com</domain>
        <domain includeSubdomains="true">script.google.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>

    <!--
         DEBUG OVERRIDE:
        - User-installed certs allowed (e.g. Charles Proxy for testing)
        - In release builds this block is IGNORED by Android
    -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
            <certificates src="system" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
