<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deep shadow layers (dark mode — using darker shades) -->
    <item android:top="6dp" android:left="6dp">
        <shape android:shape="rectangle">
            <solid android:color="#080808"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <item android:top="4dp" android:left="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#0D0D0D"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <item android:top="2dp" android:left="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#161616"/>
            <corners android:radius="24dp"/>
        </shape>
    </item>

    <!-- Dark card face -->
    <item android:bottom="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="#1E1E1E"/>
            <corners android:radius="24dp"/>
            <stroke android:width="0.5dp" android:color="#2E2E2E"/>
        </shape>
    </item>

</layer-list>
